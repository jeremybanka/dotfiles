{
  "lineWidth": 80,
  "indentWidth": 2,
  "includes": [
    "**/*.{json,jsonc,md,yml,yaml}"
  ],
  "excludes": [
    ".git/",
    "build/",
    "dist/",
    "node_modules/",
    ".zed/",
    "home/.config/gh/",
    "home/.config/lazygit/",
    "home/.config/nvim/",
    "vms/lima.yaml"
  ],
  "json": {
    "indentWidth": 2
  },
  "markdown": {
    "lineWidth": 80
  },
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ]
}
