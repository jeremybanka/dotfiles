{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": false
  },
  "minimumReleaseAge": "1 day",
  "branchConcurrentLimit": 10,
  "prHourlyLimit": 10,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^vms\\/flake\\.nix$/"],
      "matchStrings": [
        "(?<depName>nixpkgs(?:-unstable)?)\\.url\\s*=\\s*\"github:NixOS\\/nixpkgs\\/(?<currentValue>[^\"]+)\";"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/NixOS/nixpkgs",
      "versioningTemplate": "nixpkgs"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^vms\\/flake\\.lock$/"],
      "matchStrings": [
        "\"(?<depName>nixpkgs(?:-unstable)?)\":\\s*\\{\\s*\"locked\":\\s*\\{[\\s\\S]*?\"rev\":\\s*\"(?<currentDigest>[a-f0-9]{40})\"[\\s\\S]*?\\}\\s*,\\s*\"original\":\\s*\\{[\\s\\S]*?\"ref\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/NixOS/nixpkgs",
      "versioningTemplate": "exact"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/integration\\.yml$/"],
      "matchStrings": [
        "uses: jdx\\/mise-action@\\S+(?:\\s+#.*)?\\s+      with:\\s+        version: (?<currentValue>\\S+)"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "dependencyDashboardApproval": true
    },
    {
      "matchDepNames": ["jdx/mise"],
      "dependencyDashboardApproval": true
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["nixpkgs", "nixpkgs-unstable"],
      "groupName": "scrubs nix inputs",
      "groupSlug": "scrubs-nix-inputs",
      "postUpgradeTasks": {
        "commands": ["nix flake lock --update-input nixpkgs --update-input nixpkgs-unstable"],
        "fileFilters": ["vms/flake.lock"],
        "workingDirTemplate": "vms",
        "executionMode": "update",
        "installTools": {
          "nix": {}
        }
      }
    }
  ]
}
