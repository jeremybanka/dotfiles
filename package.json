{
	"name": "dotfiles",
	"type": "module",
	"scripts": {
		"helix:build-theme-agent": "bun home/.local/libexec/com.jeremybanka.helix-theme/build-plist.ts",
		"helix:set-theme": "bun home/.local/libexec/com.jeremybanka.helix-theme/theme-switcher.ts",
		"helix:theme-agent": "bun home/.local/libexec/com.jeremybanka.helix-theme/theme-switcher.ts --watch",
		"helix:watch-config": "bun scripts/watch-helix-config.ts",
		"lint:eslint": "eslint -- .",
		"lint:types": "tsc --noEmit",
		"lint": "bun run lint:eslint && bun run lint:types",
		"up": "nu ./scripts/update.nu"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@types/bun": "npm:bun-types@1.3.14",
		"@types/eslint": "9.6.1",
		"@types/node": "25.8.0",
		"@typescript-eslint/eslint-plugin": "8.59.3",
		"@typescript-eslint/parser": "8.59.3",
		"eslint": "10.4.0",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"jiti": "2.7.0",
		"prettier": "3.8.3",
		"typescript": "6.0.3",
		"typescript-language-server": "5.2.0",
		"vscode-langservers-extracted": "4.10.0"
	},
	"packages": [
		"packages/*"
	]
}
