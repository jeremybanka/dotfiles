{
	"name": "dotfiles",
	"type": "module",
	"scripts": {
		"lint:eslint": "eslint -- .",
		"lint:types": "tsc --noEmit",
		"lint": "bun run lint:eslint && bun run lint:types",
		"up": "nu ./scripts/update.nu"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@types/bun": "npm:bun-types@1.3.13",
		"@types/eslint": "9.6.1",
		"@types/node": "25.6.0",
		"@typescript-eslint/eslint-plugin": "8.59.1",
		"@typescript-eslint/parser": "8.59.1",
		"eslint": "10.3.0",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"jiti": "2.6.1",
		"prettier": "3.8.3",
		"typescript": "6.0.3"
	},
	"packages": [
		"packages/*"
	]
}
